POST http://localhost:8081/api/recommendations/investments
Content-Type: application/json

{
  "riskProfile": "CONSERVATIVE",
  "monthlyIncome": 30000,
  "monthlyExpenses": 25000,
  "monthlySavings": 5000,
  "savingsRate": 16.7,
  "investmentCapacity": 1000
}

