### Personal Finance Application - API Testing
### Includes both Personal Finance App (port 8080) and Recommendation Service (port 8081)

##########################################################################
# ==================== PERSONAL FINANCE APP (8080) ===================== #
##########################################################################

### 1. User Registration
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "email": "test@example.com",
  "password": "password123",
  "firstName": "Test",
  "lastName": "User"
}

### 2. User Login
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "usernameOrEmail": "demo",
  "password": "password123"
}

> {%
client.global.set("jwt_token", response.body.token);
%}

### 3. Get Current User Profile
GET http://localhost:8080/api/auth/me
Authorization: Bearer {{jwt_token}}

### 4. Get Dashboard Overview
GET http://localhost:8080/api/dashboard/overview
Authorization: Bearer {{jwt_token}}

### 5. Get Financial Insights
GET http://localhost:8080/api/dashboard/insights
Authorization: Bearer {{jwt_token}}

### 6. Get Monthly Trends
GET http://localhost:8080/api/dashboard/monthly-trends?monthsBack=6
Authorization: Bearer {{jwt_token}}

### 7. Get All Income
GET http://localhost:8080/api/income
Authorization: Bearer {{jwt_token}}

### 8. Add New Income
POST http://localhost:8080/api/income
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "description": "Consulting Work",
  "amount": 2000.00,
  "category": "FREELANCE",
  "date": "2024-01-15",
  "isRecurring": false,
  "notes": "One-time consulting project"
}

### 9. Get Income Categories
GET http://localhost:8080/api/income/categories
Authorization: Bearer {{jwt_token}}

### 10. Get Income by Category
GET http://localhost:8080/api/income/by-category?startDate=2024-01-01&endDate=2024-01-31
Authorization: Bearer {{jwt_token}}

### 11. Get All Expenses
GET http://localhost:8080/api/expenses
Authorization: Bearer {{jwt_token}}

### 12. Add New Expense
POST http://localhost:8080/api/expenses
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "description": "Restaurant Dinner",
  "amount": 85.50,
  "category": "FOOD",
  "date": "2024-01-15",
  "notes": "Dinner with friends"
}

### 13. Get Expenses by Category
GET http://localhost:8080/api/expenses/by-category?startDate=2024-01-01&endDate=2024-01-31
Authorization: Bearer {{jwt_token}}

### 14. Get Recent Expenses
GET http://localhost:8080/api/expenses/recent?limit=5
Authorization: Bearer {{jwt_token}}

### 15. Get All Goals
GET http://localhost:8080/api/goals
Authorization: Bearer {{jwt_token}}

### 16. Create New Goal
POST http://localhost:8080/api/goals
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "title": "Home Down Payment",
  "description": "Save for a house down payment",
  "targetAmount": 50000.00,
  "currentAmount": 5000.00,
  "targetDate": "2025-06-01",
  "priority": "HIGH"
}

### 17. Get Active Goals
GET http://localhost:8080/api/goals/active
Authorization: Bearer {{jwt_token}}

### 18. Update Goal Progress (replace {goalId} with actual ID)
PATCH http://localhost:8080/api/goals/1/add-progress
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "amount": 500.00
}

### 19. Get Goal Statistics
GET http://localhost:8080/api/goals/stats
Authorization: Bearer {{jwt_token}}

### 20. Get Investment Capacity
GET http://localhost:8080/api/investments/capacity
Authorization: Bearer {{jwt_token}}

### 21. Get Investment Recommendations (Conservative)
GET http://localhost:8080/api/investments/recommendations?riskProfile=CONSERVATIVE
Authorization: Bearer {{jwt_token}}

### 22. Get Investment Recommendations (Moderate)
GET http://localhost:8080/api/investments/recommendations?riskProfile=MODERATE
Authorization: Bearer {{jwt_token}}

### 23. Get Investment Recommendations (Aggressive)
GET http://localhost:8080/api/investments/recommendations?riskProfile=AGGRESSIVE
Authorization: Bearer {{jwt_token}}

### 24. Get Risk Profiles Information
GET http://localhost:8080/api/investments/risk-profiles
Authorization: Bearer {{jwt_token}}

### 25. Get Spending Analysis
GET http://localhost:8080/api/dashboard/spending-analysis?startDate=2024-01-01&endDate=2024-01-31
Authorization: Bearer {{jwt_token}}

##########################################################################
# ==================== FINANCIAL COACH (8080) ========================== #
# Uses user's real DB data → calls Recommendation Service for AI advice  #
##########################################################################

### 26. Get Financial Coach Advice (auto-detect risk profile from user data)
GET http://localhost:8080/api/coach/advice
Authorization: Bearer {{jwt_token}}

### 27. Get Financial Coach Advice (explicit risk profile)
GET http://localhost:8080/api/coach/advice?riskProfile=MODERATE
Authorization: Bearer {{jwt_token}}

### 28. Get Financial Coach Advice (aggressive profile)
GET http://localhost:8080/api/coach/advice?riskProfile=AGGRESSIVE
Authorization: Bearer {{jwt_token}}

##########################################################################
# ==================== AI CHAT (8080) ================================== #
# Sends user data + message to Recommendation Service Finbot AI          #
##########################################################################

### 29. AI Chat - General financial question
POST http://localhost:8080/api/chat
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "message": "How can I improve my savings this month?",
  "topic": "savings"
}

### 30. AI Chat - Investing question
POST http://localhost:8080/api/chat
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "message": "What investments should I consider given my financial situation?",
  "topic": "investing"
}

### 31. AI Chat - Debt question
POST http://localhost:8080/api/chat
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "message": "How should I manage my debt payments?",
  "topic": "debt"
}

### 32. AI Chat - General question (no topic)
POST http://localhost:8080/api/chat
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "message": "Give me a quick overview of my financial health"
}

### 33. AI Chat - With conversation ID (for follow-ups)
POST http://localhost:8080/api/chat
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "message": "Tell me more about that last point",
  "conversationId": "my-conversation-1"
}

##########################################################################
# =============== RECOMMENDATION SERVICE DIRECT (8081) ================= #
# Direct calls to the recommendation microservice (no JWT needed)        #
##########################################################################

### 34. Recommendation Service - Health Check
GET http://localhost:8081/actuator/health

### 35. Recommendation Service - Generate Investment Portfolio
POST http://localhost:8081/api/recommendations/investments
Content-Type: application/json

{
  "riskProfile": "MODERATE",
  "monthlyIncome": 50000,
  "monthlyExpenses": 30000,
  "monthlySavings": 20000,
  "savingsRate": 40.0,
  "investmentCapacity": 4000,
  "expensesByCategory": {
    "FOOD": 8000,
    "HOUSING": 12000,
    "TRANSPORTATION": 5000,
    "ENTERTAINMENT": 3000,
    "UTILITIES": 2000
  },
  "goals": [
    {
      "title": "Emergency Fund",
      "targetAmount": 100000,
      "currentAmount": 25000,
      "targetDate": "2026-12-01",
      "priority": "HIGH"
    }
  ]
}

### 36. Recommendation Service - Get Coach Advice (with profile data)
POST http://localhost:8081/api/recommendations/coach
Content-Type: application/json

{
  "riskProfile": "MODERATE",
  "monthlyIncome": 50000,
  "monthlyExpenses": 30000,
  "monthlySavings": 20000,
  "savingsRate": 40.0,
  "investmentCapacity": 4000,
  "expensesByCategory": {
    "FOOD": 8000,
    "HOUSING": 12000,
    "TRANSPORTATION": 5000,
    "ENTERTAINMENT": 3000,
    "UTILITIES": 2000
  },
  "goals": [
    {
      "title": "Emergency Fund",
      "targetAmount": 100000,
      "currentAmount": 25000,
      "targetDate": "2026-12-01",
      "priority": "HIGH"
    },
    {
      "title": "Vacation",
      "targetAmount": 50000,
      "currentAmount": 10000,
      "targetDate": "2026-06-01",
      "priority": "MEDIUM"
    }
  ]
}

### 37. Recommendation Service - Get Coach Advice with AI enrichment
POST http://localhost:8081/api/recommendations/coach?useAI=true
Content-Type: application/json

{
  "riskProfile": "AGGRESSIVE",
  "userName": "Amit",
  "monthlyIncome": 80000,
  "monthlyExpenses": 40000,
  "monthlySavings": 40000,
  "savingsRate": 50.0,
  "investmentCapacity": 8000,
  "expensesByCategory": {
    "FOOD": 10000,
    "HOUSING": 15000,
    "SHOPPING": 8000,
    "ENTERTAINMENT": 4000,
    "TRANSPORTATION": 3000
  },
  "goals": [
    {
      "title": "Buy a House",
      "targetAmount": 2000000,
      "currentAmount": 200000,
      "targetDate": "2028-01-01",
      "priority": "HIGH"
    }
  ]
}

### 38. Recommendation Service - AI Chat (bridge endpoint)
POST http://localhost:8081/api/recommendations/chat
Content-Type: application/json

{
  "message": "How should I allocate my investments given my savings rate?",
  "topic": "investing",
  "riskProfile": "MODERATE",
  "conversationId": "test-conv-1",
  "profile": {
    "monthlyIncome": 50000,
    "monthlyExpenses": 30000,
    "monthlySavings": 20000,
    "savingsRate": 40.0,
    "investmentCapacity": 4000,
    "riskProfile": "MODERATE",
    "expensesByCategory": {
      "FOOD": 8000,
      "HOUSING": 12000,
      "TRANSPORTATION": 5000
    },
    "goals": [
      {
        "title": "Emergency Fund",
        "targetAmount": 100000,
        "currentAmount": 25000,
        "targetDate": "2026-12-01"
      }
    ]
  }
}

### 39. Recommendation Service - Finbot Direct Chat
POST http://localhost:8081/api/finbot/chat
Content-Type: application/json

{
  "systemInstruction": "You are Finbot, a concise personal finance coach. Keep responses short.",
  "messages": [
    {
      "role": "user",
      "content": "I have a savings rate of 40% and earn 50,000/month. What should I invest in?"
    }
  ]
}

